# ClickHouse Cloud connection settings
# Copy this file to .env and fill in your credentials

CLICKHOUSE_HOST=your-instance.region.provider.clickhouse.cloud
CLICKHOUSE_PORT=9440
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your-password-here
CLICKHOUSE_DATABASE=pg_stat_ch
CLICKHOUSE_USE_TLS=true
CLICKHOUSE_SKIP_TLS_VERIFY=false
