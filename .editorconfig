# top-most EditorConfig file
root = true

# basic rules for all files
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true
indent_size = 2

[*.{cc,h}]
indent_style = space
indent_size = 2

[*.yaml]
indent_size = 2
indent_style = space

[*.sql]
indent_size = 4
indent_style = space

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
